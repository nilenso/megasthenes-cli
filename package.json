{
  "name": "megasthenes-cli",
  "version": "0.1.0",
  "description": "Terminal CLI for megasthenes — ask natural-language questions about any GitHub or GitLab repository and get a markdown-rendered, source-cited answer.",
  "keywords": [
    "cli",
    "llm",
    "ai",
    "code-search",
    "repository",
    "github",
    "gitlab",
    "anthropic",
    "openrouter",
    "megasthenes"
  ],
  "homepage": "https://github.com/nilenso/megasthenes-cli#readme",
  "bugs": {
    "url": "https://github.com/nilenso/megasthenes-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nilenso/megasthenes-cli.git"
  },
  "license": "MIT",
  "author": "Kiran Gangadharan <bills@nilenso.com>",
  "type": "module",
  "bin": {
    "megasthenes": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "ask": "tsx src/cli/index.ts ask",
    "test": "vitest run",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/build.mjs",
    "check:publishable": "node -e \"const d=require('./package.json').devDependencies['@nilenso/megasthenes']; if(d.startsWith('file:')||d.startsWith('link:')){console.error('refusing to publish: @nilenso/megasthenes is still a local dep ('+d+'). Bump it to a published JSR version first.');process.exit(1)}\"",
    "prepublishOnly": "npm run check:publishable && npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@nilenso/megasthenes": "npm:@jsr/nilenso__megasthenes@^0.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.7.0",
    "esbuild": "^0.24.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  }
}
